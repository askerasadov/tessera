*.dSYM
xcuserdata/
xcshareddata/

# Kotlin / KMP-specific
local.properties
.kotlin/
kotlin-js-store/

# Gradle wrapper bytecode (the wrapper jar IS committed; these are build artifacts)
.gradle/

# Environment files
.env
.env.local
.env.*.local

# Logs
*.log
logs/

# Session handoff files (working notes from individual Claude Code sessions, not project history)
SESSION-HANDOFF-*.md

# Code/doc alignment recap files (snapshot audits, not project history)
RECAP-*.md

# Coverage reports
coverage/
*.lcov
.nyc_output/

# Dependency directories (if any per-module tools introduce them)
node_modules/

# Temporary files
*.tmp
*.temp
.cache/
