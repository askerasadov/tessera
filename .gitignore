local.properties
.kotlin/
kotlin-js-store/

# Gradle wrapper bytecode (the wrapper jar IS committed; these are build artifacts)
.gradle/

# Environment files
.env
.env.local
.env.*.local

# Logs
*.log
logs/

# Session handoff files live in .handoffs/ (working notes from individual Claude Code sessions,
# not project history). The leading slash anchors the match to project root so a nested
# .handoffs/ elsewhere — should one ever appear — is not silently excluded too.
/.handoffs/

# Code/doc alignment recap files live in .recaps/ (snapshot audits, not project history).
# Same leading-slash rationale as the handoffs entry above.
/.recaps/

# Conformance verification working notes live in .conformance/ (per-session findings from
# spec-vs-implementation verification passes). Same rationale as the recap files — these are
# working artifacts, not committed project history. Leading slash for the same reason.
/.conformance/

# Local reference copies of external specifications live in .spec/ (e.g., ICAO Doc 9303 PDFs
# downloaded for implementation verification). These are NEVER committed: ICAO's terms restrict
# redistribution of their materials without written permission. The spec content is consulted
# locally to verify the SDK's implementations against authoritative source; findings translate
# into code changes and citations via section numbers, never via verbatim spec content. Leading
# slash anchors to project root (avoid accidental matches in nested module trees).
/.spec/

# Private-content scan terms file lives at .claude/private-content-terms.local (per-contributor
# local-only list of substrings that must never appear in committed files — organizational and
# location identifiers). Read by scripts/private-content-scan.sh, which is wired into the
# PreToolUse hook in .claude/settings.json to block any git push that would leak them. The
# terms themselves are the private context being protected, so the file is gitignored by design.
/.claude/private-content-terms.local

# Coverage reports
coverage/
*.lcov
.nyc_output/

# Dependency directories (if any per-module tools introduce them)
node_modules/

# Temporary files
*.tmp
*.temp
.cache/
